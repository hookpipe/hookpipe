{
  "name": "@hookflare/worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "db:migrate:local": "wrangler d1 migrations apply hookflare-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply hookflare-db --remote"
  },
  "dependencies": {
    "@hookflare/shared": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20250313.0",
    "@vitest/coverage-istanbul": "^4.1.0",
    "drizzle-kit": "^0.31.9",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
