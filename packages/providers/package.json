{
  "name": "@hookpipe/providers",
  "version": "0.1.0",
  "description": "Typed webhook provider definitions — verify signatures, parse events, validate payloads, and browse event catalogs.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/hookpipe/hookpipe",
    "directory": "packages/providers"
  },
  "homepage": "https://github.com/hookpipe/hookpipe/tree/main/packages/providers",
  "keywords": [
    "webhook",
    "webhooks",
    "provider",
    "stripe",
    "github",
    "slack",
    "shopify",
    "vercel",
    "signature",
    "verification",
    "schema",
    "zod"
  ],
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./define": {
      "types": "./dist/define.d.ts",
      "import": "./dist/define.js"
    },
    "./verify": {
      "types": "./dist/verifier.d.ts",
      "import": "./dist/verifier.js"
    },
    "./handler": {
      "types": "./dist/handler.d.ts",
      "import": "./dist/handler.js"
    },
    "./stripe": {
      "types": "./dist/stripe/index.d.ts",
      "import": "./dist/stripe/index.js"
    },
    "./github": {
      "types": "./dist/github/index.d.ts",
      "import": "./dist/github/index.js"
    },
    "./slack": {
      "types": "./dist/slack/index.d.ts",
      "import": "./dist/slack/index.js"
    },
    "./shopify": {
      "types": "./dist/shopify/index.d.ts",
      "import": "./dist/shopify/index.js"
    },
    "./vercel": {
      "types": "./dist/vercel/index.d.ts",
      "import": "./dist/vercel/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "gen": "pnpm gen:stripe && pnpm gen:github",
    "gen:stripe": "tsx scripts/gen-stripe-events.ts",
    "gen:github": "tsx scripts/gen-github-events.ts"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@octokit/webhooks-types": "^7.6.1",
    "stripe": "^20.4.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
