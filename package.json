{
  "name": "hookflare",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source webhook infrastructure built on Cloudflare Workers",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "db:migrate:local": "wrangler d1 migrations apply hookflare-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply hookflare-db --remote"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "typescript": "^5.8.0",
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0"
  }
}
